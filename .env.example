# ============================================================
# .env.example — La Manada Backend
# ============================================================
# INSTRUCCIONES:
# 1. Copiá este archivo y renombralo a: .env
# 2. Reemplazá CADA valor de ejemplo por el valor real
# 3. NUNCA subas el archivo .env a GitHub (ya está en .gitignore)
# 4. En Railway: cargar estas variables en la sección "Variables"
# ============================================================

# ─────────────────────────────────────────────
# SERVIDOR
# ─────────────────────────────────────────────

PORT=3000
NODE_ENV=production
ALLOWED_ORIGINS=https://tu-frontend.vercel.app,https://tu-dashboard.com

# ─────────────────────────────────────────────
# BASE DE DATOS (PostgreSQL en Railway)
# ─────────────────────────────────────────────

DATABASE_URL=postgresql://postgres:<TU_PASSWORD_DE_BD_AQUI>@roundhouse.proxy.rlwy.net:12345/railway

# ─────────────────────────────────────────────
# SEGURIDAD — WEBHOOK
# ─────────────────────────────────────────────

WEBHOOK_SECRET=<GENERA_CON_openssl_rand_-hex_32>

# ─────────────────────────────────────────────
# GMAIL / NODEMAILER
# ─────────────────────────────────────────────

GMAIL_USER=<TU_EMAIL_DE_GMAIL_AQUI>
GMAIL_APP_PASSWORD=<TU_APP_PASSWORD_DE_GMAIL_AQUI>
STAFF_EMAIL=<TU_EMAIL_STAFF_AQUI>

# ─────────────────────────────────────────────
# TWILIO (WhatsApp)
# ─────────────────────────────────────────────

TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=tu_auth_token_de_twilio_aqui
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
STAFF_WHATSAPP=whatsapp:+5491155550000

# ─────────────────────────────────────────────
# CLOUDINARY (Fotos)
# ─────────────────────────────────────────────

CLOUDINARY_CLOUD_NAME=tu_cloud_name_aqui
CLOUDINARY_API_KEY=<TU_API_KEY_DE_CLOUDINARY_AQUI>
CLOUDINARY_API_SECRET=tu_api_secret_de_cloudinary_aqui
